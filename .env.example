# Shared
REDIS_URL=redis://127.0.0.1:6379
SHOULD_USE_REFRESH_QUEUE=true

# API service
API_PORT=3000
WEATHER_SERVICE_URL=http://127.0.0.1:4001
NEWS_SERVICE_URL=http://127.0.0.1:4002
CURRENCY_SERVICE_URL=http://127.0.0.1:4003
STALE_AFTER_SECONDS=60
MAX_CACHE_SECONDS=3600
LOCK_WAIT_MS=2500
LOCK_POLL_MS=50
LOCK_TTL_SECONDS=5
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_SEC=60

# Mock services
WEATHER_PORT=4001
WEATHER_DELAY_MIN_MS=1000
WEATHER_DELAY_MAX_MS=2000
NEWS_PORT=4002
CURRENCY_PORT=4003
CURRENCY_MAX_PER_MINUTE=5
